# Server
MPP_SECRET_KEY=          # auto-generated if omitted; set a fixed value for persistent subscriptions
RECIPIENT_ADDRESS=       # your wallet address to receive PathUSD payments
STRIPE_CONNECTED=false   # set to "true" to enable Stripe PaymentIntent creation per period
STRIPE_SECRET_KEY=       # sk_test_... (required when STRIPE_CONNECTED=true)
PORT=3000

# Client
CLIENT_PRIVATE_KEY=      # private key of the paying wallet (0x...)
SERVER_URL=http://localhost:3000
USER_ID=demo-user        # maps to x-user-id header; one subscription per user
